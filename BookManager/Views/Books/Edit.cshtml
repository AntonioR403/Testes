@model BookManager.ViewModels.BookFormViewModel
@{
    ViewData["Title"] = "Editar livro";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h4 mb-3">Editar livro</h1>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <partial name="_BookForm" model="Model" />

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" type="submit">Guardar alterações</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
