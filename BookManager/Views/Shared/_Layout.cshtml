<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestão de Livros</title>
    <link rel="manifest" href="~/manifest.webmanifest" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="border-bottom mb-4 bg-white sticky-top">
        <nav class="navbar navbar-expand navbar-light container py-2">
            <a class="navbar-brand fw-bold" asp-controller="Books" asp-action="Index">📚 Gestão de Livros</a>
            <div class="ms-auto">
                <a class="btn btn-primary" asp-controller="Books" asp-action="Create">+ Novo livro</a>
            </div>
        </nav>
    </header>

    <main class="container pb-4">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }

        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/js/pwa.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
